# Student Companion Backend - Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# ENVIRONMENT
# ===========================================
ENVIRONMENT=development
DEBUG=true

# ===========================================
# AWS CONFIGURATION
# ===========================================
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ===========================================
# AMAZON BEDROCK (AI)
# ===========================================
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=4096

# ===========================================
# DYNAMODB
# ===========================================
# For local development:
DYNAMODB_ENDPOINT=http://dynamodb-local:8000
# For AWS (leave empty to use AWS default):
# DYNAMODB_ENDPOINT=

DYNAMODB_USERS_TABLE=student-companion-users
DYNAMODB_CONVERSATIONS_TABLE=student-companion-conversations
DYNAMODB_DOCUMENTS_TABLE=student-companion-documents
DYNAMODB_FEEDBACK_TABLE=student-companion-feedback

# ===========================================
# OPENSEARCH (RAG)
# ===========================================
# For local development:
OPENSEARCH_ENDPOINT=http://opensearch:9200
# For AWS OpenSearch:
# OPENSEARCH_ENDPOINT=https://your-domain.eu-north-1.es.amazonaws.com

OPENSEARCH_INDEX=student-companion-knowledge

# ===========================================
# S3 (Document Storage)
# ===========================================
S3_BUCKET=student-companion-documents
S3_REGION=eu-north-1

# ===========================================
# HUGGING FACE FALLBACK
# ===========================================
# Enable fallback to Hugging Face when AWS is unavailable
HUGGINGFACE_FALLBACK_ENABLED=true
HUGGINGFACE_ENDPOINT=https://ngum-alu-chatbot.hf.space

# ===========================================
# SECURITY
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://student-companion-cyan.vercel.app

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

