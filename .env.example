# Copy this file to .env and fill in the real values.
# .env is gitignored and must never be committed.

# Backend (Hugging Face Space or localhost)
VITE_API_URL=https://studentcompanion-alu-chatbot.hf.space

# Firebase project — get these from the Firebase console > Project settings.
# Restrict the API key by HTTP referrer in the Google Cloud console.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# NOTE: admin identity is decided server-side by the backend's ADMIN_EMAILS
# secret (set on the Hugging Face Space), never in the client bundle. There is
# intentionally no VITE_ADMIN_EMAILS here.

# Firestore setup
# The app writes user profile documents to the `users` collection in Firestore.
# Make sure Firestore is enabled in your Firebase project and the following
# security rule is in place (or tighter):
#
#   match /users/{uid} {
#     allow read, write: if request.auth != null && request.auth.uid == uid;
#   }
